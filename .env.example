# =============================================================================
# LicitAI — plantilla alineada al stack docker-compose del repo
# Copiar a .env y ajustar. No commitear .env con secretos reales.
# =============================================================================

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=cambiar-por-clave-larga-en-produccion
JWT_EXPIRY_MINUTES=15

# --- PostgreSQL (valores por defecto del servicio `database` en docker-compose) ---
# Si cambias POSTGRES_USER/POSTGRES_PASSWORD en compose, actualiza aquí.
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@database:5432/licitaciones

# --- Memoria / sesiones ---
MEMORY_BACKEND=postgres
MEMORY_ENCRYPTION_KEY=cambiar-por-clave-segura-32-chars-min
SQLITE_DB_PATH=./data/memory.db

# --- LLM / OCR (Ollama en el HOST; desde contenedor usar host.docker.internal) ---
OLLAMA_URL=http://host.docker.internal:11434
LLM_URL=http://host.docker.internal:11434
OCR_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# --- Vector DB (nombre de servicio en la red Docker) ---
VECTOR_DB_URL=http://vector-db:8000

# --- Redis ---
REDIS_URL=redis://queue-redis:6379
REDIS_HOST=queue-redis
REDIS_PORT=6379
QUEUE_BACKEND=redis
CACHE_BACKEND=redis
CACHE_TTL_SECONDS=3600

# --- CORS / HTTP (ver backend/ENV_VARS.md) ---
ALLOWED_ORIGINS=http://localhost:8504,http://127.0.0.1:8504

# --- Experiencia / capas opcionales (coinciden con docker-compose por defecto) ---
EXPERIENCE_LAYER_ENABLED=true
EXPERIENCE_PROMPT_INJECTION=true
EXPERIENCE_SHADOW_MODE=false
EXPERIENCE_API_ENABLED=true
EXPERIENCE_DEBUG=true

# --- Compliance (rendimiento estable; ver comentarios en app/agents/compliance.py) ---
COMPLIANCE_ADAPTIVE_CHUNKING=true
COMPLIANCE_CHUNK_MIN=3000
COMPLIANCE_CHUNK_MAX=8000
COMPLIANCE_MAX_CONCURRENT_CHUNKS=1
COMPLIANCE_CHUNK_CHARS=3000
COMPLIANCE_CHUNK_OVERLAP=300
COMPLIANCE_ZONE_N_RESULTS=5
COMPLIANCE_FORMATOS_N_RESULTS=12
COMPLIANCE_TECNICO_N_RESULTS=12
COMPLIANCE_MAX_BLOCK_SECONDS=150
COMPLIANCE_BLOCK_EMPTY_TIMEOUT_SEC=120
COMPLIANCE_BLOCK_EXTRA_RETRIES=3
COMPLIANCE_BLOCK_RETRY_DELAY_SEC=5
COMPLIANCE_MIN_SNIPPET_MATCH_PCT=40
COMPLIANCE_PASS_SNIPPET_MATCH_PCT=75

# --- CompraNet / empaquetado (CLAUDE.md) ---
COMPRANET_ALLOWED_EXT=.doc,.docx,.pdf,.jpg,.jpeg,.png,.xlsx
COMPRANET_PACKAGE_MAX_BYTES=52428800

# --- E2E monitor (scripts/e2e_monitor_job.py) ---
# E2E_API_BASE=http://127.0.0.1:8001/api/v1
# E2E_SESSION_ID=
# E2E_POLL_SEC=5
# E2E_MAX_WAIT_SEC=10800
# E2E_OUTPUTS_HOST=C:/data/outputs
# E2E_LOG_COMPLIANCE_TICKS=1

# --- Voz (opcional; no requerido para pipeline principal) ---
STT_BACKEND=whisper
TTS_BACKEND=elevenlabs
WHISPER_MODEL_SIZE=base
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE=Rachel
