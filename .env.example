# ==========================================
# GENERAL
# ==========================================
ENVIRONMENT=development  # development | production | cloud
LOG_LEVEL=INFO
SECRET_KEY=tu-clave-segura-de-32-caracteres-minimo
JWT_EXPIRY_MINUTES=15

# ==========================================
# CREDENCIALES DE BASE DE DATOS LOCAL
# ==========================================
DB_USER=licitaciones_admin
DB_PASSWORD=licitaciones_secret

# ==========================================
# MEMORIA PERSISTENTE
# ==========================================
MEMORY_BACKEND=postgres  # sqlite | postgres | firebase | mongodb
SQLITE_DB_PATH=./data/memory.db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@database:5432/licitaciones
MEMORY_ENCRYPTION_KEY=tu-clave-segura-de-32-caracteres

# ==========================================
# SERVICIOS EXTERNOS (Rutas Internas Docker)
# ==========================================
OCR_URL=http://ocr-vlm:8082
LLM_URL=http://llm-inference:11434
VECTOR_DB_URL=http://vector-db:8000

# ==========================================
# VOZ Y TRANSCRIPCIÓN
# ==========================================
STT_BACKEND=whisper  # whisper | google-speech | azure-speech
TTS_BACKEND=elevenlabs  # elevenlabs | google-tts | azure-tts
WHISPER_MODEL_SIZE=base  # tiny | base | small | medium | large
ELEVENLABS_API_KEY=sk_xxx
ELEVENLABS_DEFAULT_VOICE=Rachel

# ==========================================
# COLAS Y CACHE
# ==========================================
QUEUE_BACKEND=redis  # memory | redis | rabbitmq
REDIS_URL=redis://queue-redis:6379
CACHE_BACKEND=redis  # memory | redis
CACHE_TTL_SECONDS=3600
